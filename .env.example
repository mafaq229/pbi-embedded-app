# Power BI Embed Webapp — environment variables
# Copy this file to `.env` and fill in the values from docs/01-azure-setup.md.

# From Azure setup step A3 (App registration → Overview)
TENANT_ID=00000000-0000-0000-0000-000000000000
CLIENT_ID=00000000-0000-0000-0000-000000000000

# From Azure setup step A3 (Certificates & secrets → client secret → Value column)
CLIENT_SECRET=your-client-secret-value-here

# From Azure setup step A6 (copied from the workspace URL)
# https://app.powerbi.com/groups/{WORKSPACE_ID}/list
WORKSPACE_ID=00000000-0000-0000-0000-000000000000
